{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "e2e": {
      "extends": "preview",
      "env": { "EXPO_PUBLIC_E2E": "1" },
      "android": { "buildType": "apk" }
    }
  },
  "submit": {
    "production": {}
  }
}
